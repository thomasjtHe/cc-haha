#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# Force recovery CLI (simple readline REPL, no Ink TUI)
if [[ "${CLAUDE_CODE_FORCE_RECOVERY_CLI:-0}" == "1" ]]; then
  exec bun --env-file="$ROOT_DIR/.env" --preload "$ROOT_DIR/preload.ts" "$ROOT_DIR/src/localRecoveryCli.ts" "$@"
fi

# Default: full CLI with Ink TUI
# Note: does NOT cd to ROOT_DIR, so process.cwd() remains your current directory
exec bun --env-file="$ROOT_DIR/.env" --preload "$ROOT_DIR/preload.ts" "$ROOT_DIR/src/entrypoints/cli.tsx" "$@"
